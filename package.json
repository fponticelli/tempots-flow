{
  "name": "tempots-flow-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter @tempots/flow run build",
    "dev:basic": "pnpm --filter basic-demo run dev",
    "dev:pipeline": "pnpm --filter pipeline-demo run dev",
    "dev:visual": "pnpm --filter visual-demo run dev",
    "test": "pnpm --filter @tempots/flow run test",
    "test:watch": "pnpm --filter @tempots/flow run test:watch",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --filter @tempots/flow run typecheck",
    "check": "pnpm build && pnpm typecheck && pnpm test && pnpm lint && pnpm format:check",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
